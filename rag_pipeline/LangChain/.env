# Python RAG Pipeline Configuration
HOST=0.0.0.0
PORT=8000

# Model settings — use lightweight models for local inference
EMBEDDING_MODEL=all-MiniLM-L6-v2
LLM_MODEL=google/flan-t5-base

# FAISS vector store directory
VECTOR_STORE_DIR=./vector_stores

# Chunking parameters
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=4

# Max answer tokens
MAX_NEW_TOKENS=256
